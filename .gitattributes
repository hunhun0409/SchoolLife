# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Scripts / text
*.gd text eol=lf
*.cs text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.godot text eol=lf
*.cfg text eol=lf
*.md text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.txt text eol=lf
*.ini text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.shader text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.svg text eol=lf
*.ico binary

# Audio
*.wav binary
*.mp3 binary
*.ogg binary
*.flac binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Godot imported/binary resources
*.import text eol=lf
*.res binary
*.scn binary

# Packed/compressed files
*.zip binary
*.7z binary
*.rar binary
*.tar binary
*.gz binary

